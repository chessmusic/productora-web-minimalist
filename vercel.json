{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "laprodufilms.com" }
      ],
      "destination": "https://www.laprodufilms.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/((?!assets|laprodu|favicon.jpg|favicon.svg|icons.svg|robots.txt|sitemap.xml).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/laprodu/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    }
  ]
}
